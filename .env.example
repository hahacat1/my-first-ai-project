# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Higgsfield video generation (get from higgsfield.ai)
HIGGSFIELD_API_KEY=

# LM Studio (used for proofreading + title enrichment)
# LM_STUDIO_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=google/gemma-4-e4b

# YouTube Data API v3 (download client_secrets.json from Google Cloud Console)
# YOUTUBE_CLIENT_SECRETS=client_secrets.json

# TikTok Content Posting API v2 (apply at developers.tiktok.com, 1-7 day approval)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Publish rate limits (default: 1 full episode + 2 shorts per run)
# PUBLISH_FULL_PER_RUN=1
# PUBLISH_SHORTS_PER_RUN=2
